{
    "name": "basic-node-server",
    "version": "1.0.0",
    "description": "Minimal Node.js server with TypeScript",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon src/server.ts",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^6.0.1",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "prisma": "^6.0.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.0"
    }
}